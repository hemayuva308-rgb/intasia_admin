EMAIL_PASS=wbpjgdeshcxonbwo

EMAIL_FROM=Intasia <intasiabranding@gmail.com>
ADMIN_EMAIL=admin@intasia.in

# ── CORS / Frontend URL ────────────────────────────────────
# Set this to your actual production domain when deploying.
# For local development it defaults to localhost origins automatically.
